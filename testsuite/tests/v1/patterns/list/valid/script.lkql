val int_lst = [1, 2, 3]
val lst_lst = [int_lst, int_lst]

print("=== Should be true")
print(int_lst is [1, 2, 3])
print(int_lst is [1, 2, ...])
print(int_lst is [1, ...])
print(int_lst is [1, remains@...] when remains is [2, 3])
print(lst_lst is [[1, 2, 3], remains@...] when remains is [[1, 2, 3]])
print("")

print("=== Should be false")
print(int_lst is [1, 2])
print(int_lst is [1, 2, 4])
print(int_lst is [1, 2, 3, 4])
print(int_lst is [1, 2, 3, 4, ...])
print("not a list" is [1, 2, 3])
